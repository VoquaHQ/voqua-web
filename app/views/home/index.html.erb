  <div class="py-24 px-6 bg-white">
    <div class="mx-auto max-w-5xl">
      <h2 class="text-4xl font-black text-center mb-16">ALREADY MAKING AN IMPACT AT</h2>

      <div class="flex flex-wrap justify-center items-center gap-12 sm:gap-20">
        <a href="https://www.flexecharge.com/" target="_blank" rel="noopener" class="w-48 h-24 flex items-center justify-center border-2 border-black p-4 transition-opacity hover:opacity-80">
          <%= image_tag "FlexeCharge_tr_1-1.png", class: "w-full h-auto", alt: "FlexeCharge Logo" %>
        </a>

        <a href="https://www.frankfurt-school.de/en/home" target="_blank" rel="noopener" class="w-48 h-24 flex items-center justify-center border-2 border-black p-4 transition-opacity hover:opacity-80">
          <%= image_tag "Logo_FS_CMYK.jpg", class: "w-full h-auto", alt: "Frankfurt School Logo" %>
        </a>
      </div>
    </div>
  </div>

  <!-- Team Section -->
  <div class="py-24 px-6 bg-gray-50">
    <div class="mx-auto max-w-5xl">
      <h2 class="text-4xl font-black text-center mb-20">OUR TEAM</h2>

      <div class="space-y-20">
        <div>
          <h3 class="text-2xl font-bold mb-12 border-b-2 border-black pb-2">EXECUTIVES</h3>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
            <div class="border-2 border-black p-8 bg-white hover:bg-black hover:text-white transition-colors duration-500">
              <h4 class="text-xl font-bold mb-2">Leon Erichsen</h4>
              <p class="text-gray-800">
                Previously: Product Manager & Researcher at Human Passport, Gitcoin, RadicalxChange Foundation
              </p>
            </div>

            <div class="border-2 border-black p-8 bg-white hover:bg-black hover:text-white transition-colors duration-500">
              <h4 class="text-xl font-bold mb-2">Andrea Franz</h4>
              <p class="text-gray-800">
                Previously: Developer with 20 years' experience including Gitcoin, Status, Nature
              </p>
            </div>
          </div>
        </div>

        <div>
          <h3 class="text-2xl font-bold mb-12 border-b-2 border-black pb-2">ADVISORS</h3>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
            <div class="border-2 border-black p-8 bg-white hover:bg-black hover:text-white transition-colors duration-500">
              <h4 class="text-xl font-bold mb-2">Matt Prewitt</h4>
              <p class="text-gray-800">
                President of RadicalxChange Foundation; Writer; Former Antitrust Litigator
              </p>
            </div>

            <div class="border-2 border-black p-8 bg-white hover:bg-black hover:text-white transition-colors duration-500">
              <h4 class="text-xl font-bold mb-2">Michele Zanini</h4>
              <p class="text-gray-800">
                Co-Author of Humanocracy; Co-Founder of Management Lab; Former McKinsey Senior Consultant
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- CTA Section -->
  <div class="py-24 px-6 bg-white">
    <div class="mx-auto max-w-5xl">
      <div class="text-center mb-12">
        <h2 class="text-5xl sm:text-6xl font-black text-black mb-6">
          END DECISION<br />BOTTLENECKS
        </h2>
        <p class="text-xl text-gray-800 max-w-2xl mx-auto">
          Join forward-thinking organizations unlocking collective intelligence with Voqua's prioritization platform.
        </p>
      </div>

      <div class="flex flex-col items-center justify-center gap-8">
        <a
          href="/beta"
          class="px-10 py-5 text-xl font-bold text-white bg-black hover:bg-gray-900 transition-all duration-300 rounded-none"
        >
          <span class="flex items-center">
            MAKE SMARTER DECISIONS TODAY
            <svg class="ml-2 w-5 h-5" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"/><path d="m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"/><path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0"/><path d="M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5"/></svg>
          </span>
        </a>

        <div class="flex gap-8 text-base mt-10 font-bold">
          <a href="https://voqua.substack.com/" target="_blank" rel="noopener" class="text-black hover:text-gray-600 hover:underline">BLOG</a>
          <a href="https://bsky.app/profile/voqua.bsky.social" target="_blank" rel="noopener" class="text-black hover:text-gray-600 hover:underline">BLUESKY</a>
          <a href="https://www.linkedin.com/company/voqua" target="_blank" rel="noopener" class="text-black hover:text-gray-600 hover:underline">LINKEDIN</a>
          <a href="https://x.com/VoquaHQ" target="_blank" rel="noopener" class="text-black hover:text-gray-600 hover:underline">X</a>
        </div>
      </div>
    </div>
  </div>

