<div class="min-h-screen bg-white">
  <!-- Hero Section -->
  <div class="relative isolate px-6 pt-14 lg:px-8">
    <div class="mx-auto max-w-5xl py-32 sm:py-48">
      <div class="text-center" data-landing-target="fadeIn" data-transition-enter="transition ease-out duration-500" data-transition-enter-start="opacity-0 translate-y-4" data-transition-enter-end="opacity-100 translate-y-0">
        <div class="mb-4 flex justify-center items-center">
          <div class="relative">
            <div class="bg-white border-2 border-black rounded-full px-4 py-1 text-xs font-bold tracking-widest uppercase">
              <span data-controller="flashing-text" data-flashing-text-interval-value="2000">COLLECTIVE INTELLIGENCE</span>
            </div>
          </div>
        </div>

        <h1 class="text-6xl sm:text-7xl font-black tracking-tight text-black mt-6 mb-12 leading-none">
          <span class="text-reveal">UNLEASH</span>
          <span class="text-reveal animate-delay-100 relative">
            <span class="relative z-10">EMERGENT</span>
            <span class="absolute -inset-1 bg-neon-yellow opacity-10 blur-sm"></span>
          </span>
          <span class="text-reveal animate-delay-200">INTELLIGENCE</span>
        </h1>

        <p class="mt-6 text-xl sm:text-2xl leading-8 text-gray-800 max-w-3xl mx-auto">
          <span data-controller="glitch-text" data-glitch-text-value="Not just another voting app. A computational system that transforms how organizations think, adapt, and evolve together." data-glitch-text-glitch-interval-value="5000">
            Not just another voting app. A computational system that transforms how organizations think, adapt, and evolve together.
          </span>
        </p>

        <div class="mt-14 flex flex-wrap items-center justify-center gap-8">
          <a
            href="/beta"
            class="px-8 py-4 text-lg font-bold text-white bg-black hover:bg-gray-900 transition-all duration-300 rounded-none"
          >
            <span class="flex items-center">
              AMPLIFY INTELLIGENCE
              <svg class="ml-2 w-4 h-4" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"/><path d="m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"/><path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0"/><path d="M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5"/></svg>
            </span>
          </a>

          <a
            href="https://voqua.substack.com/"
            class="text-black text-lg font-bold hover:underline"
            target="_blank"
            rel="noopener"
          >
            Learn More →
          </a>
        </div>
      </div>
    </div>

    <!-- Marquee Banner -->
    <div class="w-full py-8 bg-black text-white overflow-hidden mt-24">
      <div class="flex justify-center">
        <div class="marquee w-full max-w-5xl" data-controller="marquee-text" data-marquee-text-speed-value="normal">
          <div class="marquee-content flex items-center gap-8">
            <svg class="w-6 h-6 flex-shrink-0" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
            <span class="text-xl font-black whitespace-nowrap">COLLECTIVE INTELLIGENCE</span>
            <svg class="w-6 h-6 flex-shrink-0" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 7.5v0M12 16.5v0"/><path d="M8.7 10.6c.3-.1.5-.1.8-.1h1c.3 0 .5.1.8.1.3.1.4.2.6.4.1.2.2.4.2.7 0 .3-.1.5-.2.7-.1.2-.3.3-.5.4-.2.1-.5.2-.8.2h-1c-.3 0-.6-.1-.8-.2-.2-.1-.4-.2-.5-.4-.1-.2-.2-.4-.2-.7 0-.3.1-.5.2-.7.2-.2.3-.3.6-.4Z"/><path d="M8.7 13.4c.3-.1.5-.1.8-.1h1c.3 0 .5.1.8.1.3.1.4.2.6.4.1.2.2.4.2.7 0 .3-.1.5-.2.7-.1.2-.3.3-.5.4-.2.1-.5.2-.8.2h-1c-.3 0-.6-.1-.8-.2-.2-.1-.4-.2-.5-.4-.1-.2-.2-.4-.2-.7 0-.3.1-.5.2-.7.2-.2.3-.3.6-.4Z"/></svg>
            <span class="text-xl font-black whitespace-nowrap">EMERGENT DECISION-MAKING</span>
            <svg class="w-6 h-6 flex-shrink-0" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="4"/><circle cx="12" cy="12" r="2"/><path d="M12 6v0"/><path d="M12 18v0"/><path d="M6 12h0"/><path d="M18 12h0"/></svg>
            <span class="text-xl font-black whitespace-nowrap">ADAPTIVE ORGANIZATIONS</span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Features Section -->
  <div class="py-24 px-6 bg-white">
    <div class="mx-auto max-w-5xl">
      <div class="mb-20 text-center">
        <h2 class="text-4xl sm:text-5xl font-black text-black">
          WHY THE FUTURE NEEDS VOQUA
        </h2>
        <div class="w-24 h-1 bg-black mx-auto mt-6 mb-8"></div>
        <p class="text-xl text-gray-800 max-w-3xl mx-auto">
          Most organizations are operating with industrial-era decision models in a post-industrial world.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="border-2 border-black p-8 hover:bg-black hover:text-white transition-colors duration-300 group">
          <div class="h-14 w-14 mb-6 rounded-none bg-black group-hover:bg-white flex items-center justify-center">
            <svg class="w-8 h-8 text-white group-hover:text-black transition-colors duration-300" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
          </div>
          <h3 class="text-2xl font-bold mb-4">SPEED</h3>
          <p class="text-lg">
            Break free from decision bottlenecks. Our computational systems capture collective intelligence and compress weeks of meetings into hours.
          </p>
        </div>

        <div class="border-2 border-black p-8 hover:bg-black hover:text-white transition-colors duration-300 group">
          <div class="h-14 w-14 mb-6 rounded-none bg-black group-hover:bg-white flex items-center justify-center">
            <svg class="w-8 h-8 text-white group-hover:text-black transition-colors duration-300" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 7.5v0M12 16.5v0"/><path d="M8.7 10.6c.3-.1.5-.1.8-.1h1c.3 0 .5.1.8.1.3.1.4.2.6.4.1.2.2.4.2.7 0 .3-.1.5-.2.7-.1.2-.3.3-.5.4-.2.1-.5.2-.8.2h-1c-.3 0-.6-.1-.8-.2-.2-.1-.4-.2-.5-.4-.1-.2-.2-.4-.2-.7 0-.3.1-.5.2-.7.2-.2.3-.3.6-.4Z"/><path d="M8.7 13.4c.3-.1.5-.1.8-.1h1c.3 0 .5.1.8.1.3.1.4.2.6.4.1.2.2.4.2.7 0 .3-.1.5-.2.7-.1.2-.3.3-.5.4-.2.1-.5.2-.8.2h-1c-.3 0-.6-.1-.8-.2-.2-.1-.4-.2-.5-.4-.1-.2-.2-.4-.2-.7 0-.3.1-.5.2-.7.2-.2.3-.3.6-.4Z"/></svg>
          </div>
          <h3 class="text-2xl font-bold mb-4">ALIGNMENT</h3>
          <p class="text-lg">
            End the politics of decision-making. Surface real priorities and enable true alignment around what actually matters.
          </p>
        </div>

        <div class="border-2 border-black p-8 hover:bg-black hover:text-white transition-colors duration-300 group">
          <div class="h-14 w-14 mb-6 rounded-none bg-black group-hover:bg-white flex items-center justify-center">
            <svg class="w-8 h-8 text-white group-hover:text-black transition-colors duration-300" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="4"/><circle cx="12" cy="12" r="2"/><path d="M12 6v0"/><path d="M12 18v0"/><path d="M6 12h0"/><path d="M18 12h0"/></svg>
          </div>
          <h3 class="text-2xl font-bold mb-4">INTELLIGENCE</h3>
          <p class="text-lg">
            Transform how your organization thinks. Unlock emergent intelligence across dynamic, accountable stakeholder groups.
          </p>
        </div>
      </div>
    </div>
  </div>

  <!-- Manifesto Section -->
  <div class="py-24 px-6 bg-black text-white">
    <div class="mx-auto max-w-5xl">
      <div class="mb-16 text-center">
        <h2 class="text-4xl sm:text-5xl font-black">
          WE ARE NOT OPTIMIZING—WE ARE <span data-controller="flashing-text">REENGINEERING</span>
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-16">
        <div>
          <h3 class="text-3xl font-bold mb-6">THIS ISN'T ABOUT DEMOCRACY</h3>
          <p class="text-xl leading-relaxed">
            It's about <span class="font-bold">intelligence</span>. About unlocking the collective
            knowledge, wisdom, and judgment distributed throughout your organization.
            About turning diverse input into decisions that stick.
          </p>
        </div>

        <div>
          <h3 class="text-3xl font-bold mb-6">THIS ISN'T INCREMENTAL</h3>
          <p class="text-xl leading-relaxed">
            We're building computational systems that enable fluid cooperation across dynamic stakeholder groups—establishing a
            new foundation for corporate intelligence that is adaptive, high-trust, and built for complexity.
          </p>
        </div>
      </div>

      <div class="mt-16 flex justify-center">
        <a
          href="/beta"
          class="px-10 py-4 text-lg font-bold text-black bg-white hover:bg-gray-100 transition-all duration-300 rounded-none"
        >
          <span class="flex items-center">
            JOIN THE MOVEMENT
