<div class="min-h-screen bg-white" data-controller="landing">
  <div class="relative isolate px-6 pt-14 lg:px-8">
    <div class="mx-auto max-w-4xl py-32">
      <div data-landing-target="fadeIn">
        <h1 class="text-4xl font-bold tracking-tight text-gray-900 sm:text-6xl font-display mb-8">
          Try Quadratic Voting Today
        </h1>
        <p class="text-lg leading-8 text-gray-600">
          Organize a simple vote instantly with our self-serve tool, or get enterprise-grade decision support with custom implementation and consulting for your organization.
        </p>
        
        <div class="mt-10 flex items-center gap-4">
          <a href="/users/sign_up" class="inline-flex items-center justify-center rounded-md bg-indigo-600 px-8 py-3 text-base font-semibold text-white shadow-sm hover:bg-indigo-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600 transition-all duration-300 hover:scale-105">
            Start Free Now
          </a>
          <a href="mailto:hello@voqua.io" class="inline-flex items-center justify-center rounded-md px-8 py-3 text-base font-semibold text-indigo-600 hover:text-indigo-500">
            Enterprise Solutions
          </a>
        </div>

        <div class="mt-24 bg-gray-50 p-8 rounded-xl shadow-sm" data-transition-enter="transition ease-out duration-500" data-transition-enter-start="opacity-0 translate-y-4" data-transition-enter-end="opacity-100 translate-y-0">
          <h2 class="text-2xl font-bold text-gray-900 font-display mb-8">How Quadratic Voting Works</h2>
          
          <div class="mb-8">
            <div class="flex justify-center mb-6">
              <%= image_tag "demo.png", class: "rounded-lg shadow-sm max-w-full h-auto", alt: "Quadratic Voting Demo" %>
            </div>
            <p class="text-gray-600 text-center">Real example: Prioritizing an innovation roadmap with team input</p>
          </div>
          
          <div class="space-y-6">
            <div class="flex gap-4 items-start">
              <div class="h-8 w-8 flex-none rounded-lg bg-indigo-600 text-white flex items-center justify-center">
                <span class="text-lg">1</span>
              </div>
              <div>
                <h3 class="font-semibold text-gray-900">Create Your Ballot</h3>
                <p class="mt-2 text-gray-600">Add the options you need input on - from project priorities to strategic decisions.</p>
              </div>
            </div>
            <div class="flex gap-4 items-start">
              <div class="h-8 w-8 flex-none rounded-lg bg-indigo-600 text-white flex items-center justify-center">
                <span class="text-lg">2</span>
              </div>
              <div>
                <h3 class="font-semibold text-gray-900">Participants Vote</h3>
                <p class="mt-2 text-gray-600">Everyone allocates their voting credits, showing how strongly they feel about each option.</p>
              </div>
            </div>
            <div class="flex gap-4 items-start">
              <div class="h-8 w-8 flex-none rounded-lg bg-indigo-600 text-white flex items-center justify-center">
                <span class="text-lg">3</span>
              </div>
              <div>
                <h3 class="font-semibold text-gray-900">Get Clear Results</h3>
                <p class="mt-2 text-gray-600">See exactly what matters most to your team with results that reflect true preferences.</p>
              </div>
            </div>
          </div>
        </div>

        <div class="mt-16 bg-white p-8 rounded-xl border border-gray-200" data-transition-enter="transition ease-out duration-500" data-transition-enter-start="opacity-0 translate-y-4" data-transition-enter-end="opacity-100 translate-y-0">
          <h2 class="text-2xl font-bold text-gray-900 font-display mb-4">Enterprise Decision Support</h2>
          <p class="text-gray-600">
            For organizations that need more than a simple vote, our enterprise solution includes consulting, custom implementation, and leadership-focused insights.
          </p>
          <div class="mt-6 space-y-4">
            <div class="flex items-start">
              <svg class="w-5 h-5 text-indigo-600 mr-2 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
              <p class="text-gray-600">Tailored to your organization's decision-making needs</p>
            </div>
            <div class="flex items-start">
              <svg class="w-5 h-5 text-indigo-600 mr-2 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
              <p class="text-gray-600">Integration with your existing workflows and systems</p>
            </div>
            <div class="flex items-start">
              <svg class="w-5 h-5 text-indigo-600 mr-2 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
              <p class="text-gray-600">Consulting and oversight for successful adoption</p>
            </div>
          </div>
          <div class="mt-6">
            <a href="mailto:hello@voqua.io" class="text-indigo-600 hover:text-indigo-500 font-semibold">Contact Us →</a>
          </div>
        </div>

        <div class="mt-16" data-transition-enter="transition ease-out duration-500 delay-[300ms]" data-transition-enter-start="opacity-0" data-transition-enter-end="opacity-100">
          <p class="text-sm text-gray-600">
            Questions about Quadratic Voting? Email us at <a href="mailto:hello@voqua.io" class="text-indigo-600 hover:text-indigo-500 font-semibold">hello@voqua.io</a>
          </p>
        </div>
      </div>
    </div>
  </div>
</div>
