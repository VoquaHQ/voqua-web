<%= render "layouts/shared/header" %>

<main class="container mx-auto pt-24">
  <% if flash.any? %>
    <% flash.each do |k, v|; next if k == "timedout" %>
      <div class="alert alert-<%= k %>" role="alert" data-controller="alert" data-show="true">
        <div class="flex items-center gap-3">
          <% if k == "success" %>
            <svg class="h-5 w-5 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
            </svg>
          <% elsif k == "error" %>
            <svg class="h-5 w-5 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
            </svg>
          <% else %>
            <svg class="h-5 w-5 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          <% end %>
          <span class="block sm:inline"><%= v %></span>
        </div>
        <button type="button" class="close flex items-center justify-center h-6 w-6 rounded-full hover:bg-black/5 transition-colors">
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>
    <% end %>
  <% end %>
  <%= yield %>
</main>

<%= render "layouts/shared/footer" %>
