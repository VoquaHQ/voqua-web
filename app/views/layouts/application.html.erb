<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Quadratic Voting MVP</title>
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>

  <%= stylesheet_link_tag "tailwind", "inter-font", "data-turbo-track": "reload" %>
  <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
  <%= javascript_importmap_tags %>
</head>

<body class="bg-gray-100">
  <header class="bg-white shadow-md">
    <nav class="container mx-auto px-4 py-4">
      <%= link_to 'Quadratic Voting', root_path, class: 'text-2xl font-bold text-blue-600' %>
      <% if user_signed_in? %>
        <%= link_to 'Dashboard', dashboard_path, class: 'ml-4 text-gray-600 hover:text-gray-800' %>
        <%= link_to 'Sign Out', destroy_user_session_path, method: :delete, class: 'ml-4 text-gray-600 hover:text-gray-800' %>
      <% else %>
        <%= link_to 'Sign In', new_user_session_path, class: 'ml-4 text-gray-600 hover:text-gray-800' %>
        <%= link_to 'Sign Up', new_user_registration_path, class: 'ml-4 text-gray-600 hover:text-gray-800' %>
      <% end %>
    </nav>
  </header>

  <main class="container mx-auto px-4 py-8">
    <% if notice %>
      <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded relative mb-4" role="alert">
        <%= notice %>
      </div>
    <% end %>
    <% if alert %>
      <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded relative mb-4" role="alert">
        <%= alert %>
      </div>
    <% end %>

    <%= yield %>
  </main>

  <footer class="bg-white shadow-md mt-8">
    <div class="container mx-auto px-4 py-4 text-center text-gray-600">
      &copy; <%= Time.current.year %> Quadratic Voting MVP. All rights reserved.
    </div>
  </footer>
</body>
</html>
