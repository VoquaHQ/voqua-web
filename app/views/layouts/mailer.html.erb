<!DOCTYPE html>
<html>
  <head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <style>
      body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
        color: #333333;
        line-height: 1.5;
        margin: 0;
        padding: 0;
      }
      .container {
        max-width: 600px;
        margin: 0 auto;
        padding: 20px;
      }
      .header {
        text-align: left;
        margin-bottom: 30px;
      }
      .content {
        background: #ffffff;
        padding: 30px;
      }
      .button {
        display: inline-block;
        padding: 12px 24px;
        background-color: #4A5568;
        color: #ffffff;
        text-decoration: none;
        border-radius: 6px;
        margin: 20px 0;
      }
      .footer {
        margin-top: 30px;
        font-size: 14px;
        color: #666666;
        text-align: center;
      }
    </style>
  </head>
  <body>
    <div class="container">
      <div class="header">
        <strong style="font-size: 24px;">Voqua</strong>
      </div>
      <div class="content">
        <%= yield %>
      </div>
      <div class="footer">
        <p>Sent by Voqua - Quadratic Voting for Organizations</p>
      </div>
    </div>
  </body>
</html>
