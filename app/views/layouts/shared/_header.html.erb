<!DOCTYPE html>
<html>
  <head>
    <title>Voqua - Make Better Decisions, Faster</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="description" content="Make decisions in days, not weeks. Voqua's intelligent prioritization system helps teams align quickly on what matters most, cutting through politics and driving real results.">

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website">
    <meta property="og:url" content="<%= request.base_url %>">
    <meta property="og:title" content="Voqua - Make Better Decisions, Faster">
    <meta property="og:description" content="Make decisions in days, not weeks. Voqua's intelligent prioritization system helps teams align quickly on what matters most.">
    <meta property="og:image" content="<%= image_url "logo.svg" %>">

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:url" content="<%= request.base_url %>">
    <meta name="twitter:title" content="Voqua - Make Better Decisions, Faster">
    <meta name="twitter:description" content="Make decisions in days, not weeks. Voqua's intelligent prioritization system helps teams align quickly on what matters most.">
    <meta name="twitter:image" content="<%= image_url "logo.svg" %>">

    <!-- Additional SEO -->
    <meta name="keywords" content="decision making, team alignment, prioritization, resource allocation, decision support, data-driven decisions, team decisions, enterprise decision tools">
    <meta name="author" content="Voqua">
    <link rel="canonical" href="<%= request.base_url %>">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "tailwind", "inter-font", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <link rel="icon" href="<%= image_path "logo.svg" %>">

    <!-- Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-RVCRBRGSL6"></script>
    <script>
      const gaId = "G-RVCRBRGSL6";
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      document.addEventListener("turbo:load", () => {
        console.log("turbo:load");
        gtag('config', gaId, {
          page_path: window.location.pathname,
        });
      });
    </script>
  </head>

  <body class="bg-white">
    <%= render "layouts/shared/nav" %>
