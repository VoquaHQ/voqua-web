<a href="<%= ballots_list_item_path(current_user, ballot) %>" class="block hover:bg-gray-50 transition-colors duration-150">
  <div class="p-6 flex items-center justify-between">
    <div class="min-w-0 flex-1">
      <h3 class="text-lg font-medium text-gray-900 truncate"><%= ballot.name %></h3>
      <div class="mt-1 flex items-center">
        <div class="flex-shrink-0 w-2.5 h-2.5 rounded-full bg-green-400 mr-2"></div>
        <p class="text-sm text-gray-600">
          <%= format_end_date(ballot.ends_at) %>
          - created by <%= ballot.profile.handle %>
        </p>
      </div>
    </div>
    <div class="ml-6">
      <svg class="h-5 w-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
      </svg>
    </div>
  </div>
</a>
