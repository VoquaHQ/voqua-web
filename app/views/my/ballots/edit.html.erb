<div class="container max-w-5xl mx-auto px-6">
  <h2 class="text-2xl font-bold mb-6">Edit Your Voqua</h2>

  <%= form_with model: @ballot, url: my_ballot_path(@ballot), local: true, data: { turbo: false } do |f| %>
    <div class="pb-12 space-y-6">
      <%= render 'form', ballot: @ballot, f: f %>

      <div class="flex space-x-4 p-y 4">
        <%= f.submit "Update Voqua", class: "button button-primary" %>
        <%= link_to "Cancel", my_ballots_path, class: "button button-secondary" %>
      </div>
    </div>
  <% end %>
</div>
