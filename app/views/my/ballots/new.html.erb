<div class="min-h-screen bg-gray-50">
  <div class="max-w-2xl mx-auto px-4 py-12">
    <div class="mb-8">
      <h1 class="text-2xl font-medium text-gray-900">New Vote</h1>
    </div>

    <div class="bg-white rounded-xl shadow-sm border border-gray-200/75">
      <%= form_with model: @ballot, url: my_ballots_path, local: true, data: { turbo: false } do |f| %>
        <div class="p-6">
          <%= render 'form', ballot: @ballot, f: f %>
        </div>

        <div class="px-6 py-4 bg-gray-50 border-t border-gray-200/75 flex items-center justify-end gap-3">
          <%= link_to "Cancel", my_ballots_path, class: "px-4 py-2 text-sm font-medium text-gray-700 hover:text-gray-800 transition-colors duration-200" %>
          <%= f.submit "Create", class: "px-4 py-2 text-sm font-medium rounded-lg text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-all duration-200" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
