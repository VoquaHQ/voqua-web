<div class="bg-white rounded-lg shadow-sm p-6 mb-8">
  <h2 class="text-2xl font-bold mb-6"><%= @ballot.name %></h1>
  <p><%= @ballot.description %></p>
  <%= link_to 'Edit', edit_my_ballot_path(@ballot) %> |
  <%= link_to 'Public Link', ballot_path(@ballot), target: :_blank %>
</div>

<div class="bg-white rounded-lg shadow-sm p-6 mb-8">
  <h2 class="text-2xl font-bold mb-6">Questions</h2>
  <% if @ballot.questions.empty? %>
    <p>There are no questions for this ballot.</p>
  <% else %>
    <ul>
      <% @ballot.questions.each do |question| %>
        <li>
          <%= question.title %> -
          <%= question.description %>
          (
            <%= link_to 'Delete', my_ballot_question_path(@ballot, question), data: { turbo_method: :delete, turbo_confirm: 'Are you sure?' } %>
          )
        </li>
      <% end %>
    </ul>
  <% end %>

  <hr />

  <h2>Add Question</h2>

  <%= form_with model: @question, url: my_ballot_questions_path(@ballot), local: true, data: { turbo: false } do |f| %>
    <%= render "my/questions/form", question: @question, f: f %>
  <% end %>
</div>

<div class="bg-white rounded-lg shadow-sm p-6 mb-8">
  <% if @ballot.private? %>
    <h2 class="text-2xl font-bold mb-6">Members</h2>

    <% if @ballot.invitations.empty? %>
      <p class="my-6 text-center text-gray-500">There are no members for this ballot.</p>
    <% else %>
      <div class="relative flex flex-col w-full h-full overflow-scroll text-gray-700 bg-white shadow-md rounded-xl bg-clip-border mb-8">
        <table class="w-full text-left table-auto min-w-max">
          <thead>
            <tr>
              <th class="p-4 border-b border-blue-gray-100 bg-gray-50"><span class="block font-sans text-sm font-normal leading-none text-blue-gray-900 antialiased opacity-70">Email</span></th>
              <th class="p-4 border-b border-blue-gray-100 bg-gray-50"><span class="block font-sans text-sm font-normal leading-none text-blue-gray-900 antialiased opacity-70">Accepted By</span></th>
              <th class="p-4 border-b border-blue-gray-100 bg-gray-50"><span class="block font-sans text-sm font-normal leading-none text-blue-gray-900 antialiased opacity-70">Accepted At</span></th>
              <th class="p-4 border-b border-blue-gray-100 bg-gray-50 text-right"><span class="block font-sans text-sm font-normal leading-none text-blue-gray-900 antialiased opacity-70">-</span></th>
            </tr>
          </thead>
          <tbody>
            <% @ballot.invitations.each do |invitation| %>
              <tr>
                <td class="p-4 border-b border-blue-gray-50">
                  <p class="block font-sans text-sm font-normal leading-normal text-blue-gray-900 antialiased">
                    <%= invitation.email %>
                  </p>
                </td>
                <td class="p-4 border-b border-blue-gray-50">
                  <p class="block font-sans text-sm font-normal leading-normal text-blue-gray-900 antialiased">
                    <%= invitation.accepted_by.try(:handle) %>
                  </p>
                </td>
                <td class="p-4 border-b border-blue-gray-50">
                  <p class="block font-sans text-sm font-normal leading-normal text-blue-gray-900 antialiased">
                    <%= invitation.accepted_at %>
                  </p>
                </td>
                <td class="p-4 border-b border-blue-gray-50 text-right">
                  <%= link_to 'remove', my_ballot_ballot_invitation_path(@ballot, invitation), data: { turbo_method: :delete, turbo_confirm: 'Are you sure?' } %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% end %>

    <%= form_tag bulk_create_my_ballot_ballot_invitations_path(@ballot), data: { turbo: false }, class: "form" do %>
      <label for="emails">Invite Members</label>
      <%= text_area_tag :emails, nil, placeholder: 'Emails (comma separated or new lines)', rows: 5, class: "w-full" %>
      <div class="text-right">
      <%= submit_tag "Invite", class: "button button-primary" %>
      </div>
    <% end %>
  <% end %>
</div>
