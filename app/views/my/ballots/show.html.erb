<div class="min-h-screen bg-gray-50">
  <div class="max-w-4xl mx-auto px-4 py-12">
    <%# Header Section %>
    <div class="mb-8">
      <div class="flex items-start justify-between">
        <div>
          <h1 class="text-2xl font-medium text-gray-900"><%= @ballot.name %></h1>
          <% if @ballot.description.present? %>
            <p class="mt-2 text-gray-600"><%= @ballot.description %></p>
          <% end %>
        </div>
        <%= link_to edit_my_ballot_path(@ballot), class: "text-sm text-gray-600 hover:text-gray-900" do %>
          Edit
        <% end %>
      </div>
    </div>

    <%# Voting Link Section %>
    <% if @ballot.ends_at > Time.now %>
      <div class="mb-8 bg-white rounded-xl shadow-sm border border-gray-200/75 overflow-hidden">
        <div class="px-6 py-5 flex items-center justify-between">
          <div>
            <h2 class="text-sm font-medium text-gray-900">Voting Link</h2>
            <p class="mt-1 text-sm text-gray-500">Share this link with voters</p>
          </div>
          <div class="flex items-center gap-3">
            <a href="<%= ballot_path %>" target="_blank" class="px-4 py-2 text-sm font-medium rounded-lg text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-all duration-200">
              Open Vote
            </a>
            <a href="<%= results_ballot_path %>" target="_blank" class="px-4 py-2 text-sm font-medium text-gray-700 hover:text-gray-900 transition-colors duration-200">
              Results
            </a>
          </div>
        </div>
      </div>
    <% end %>

    <%# Options Section %>
    <div class="mb-8 bg-white rounded-xl shadow-sm border border-gray-200/75 overflow-hidden">
      <div class="px-6 py-5 border-b border-gray-200/75">
        <h2 class="text-sm font-medium text-gray-900">Options</h2>
      </div>

      <div class="divide-y divide-gray-200/75">
        <% if @ballot.questions.any? %>
          <% @ballot.questions.each do |question| %>
            <div class="px-6 py-4 flex items-start justify-between group">
              <div>
                <h3 class="text-sm font-medium text-gray-900"><%= question.title %></h3>
                <% if question.description.present? %>
                  <p class="mt-1 text-sm text-gray-500"><%= question.description %></p>
                <% end %>
              </div>
              <%= link_to 'Remove',
                  my_ballot_question_path(@ballot, question),
                  data: { turbo_method: :delete, turbo_confirm: 'Are you sure?' },
                  class: "opacity-0 group-hover:opacity-100 text-xs text-gray-500 hover:text-red-600 transition-all duration-200" %>
            </div>
          <% end %>
        <% end %>

        <%# Add Option Form %>
        <div class="px-6 py-5 bg-gray-50/50">
          <%= form_with model: @question,
              url: my_ballot_questions_path(@ballot),
              local: true,
              data: { turbo: false } do |f| %>
            <%= render "my/questions/form", question: @question, f: f %>
          <% end %>
        </div>
      </div>
    </div>

    <%# Members Section (if private) %>
    <% if @ballot.private? %>
      <div class="mb-8 bg-white rounded-xl shadow-sm border border-gray-200/75 overflow-hidden">
        <div class="px-6 py-5 border-b border-gray-200/75">
          <h2 class="text-sm font-medium text-gray-900">Members</h2>
        </div>

        <%# Member List %>
        <div class="divide-y divide-gray-200/75">
          <% @ballot.invitations.each do |invitation| %>
            <div class="px-6 py-3 flex items-center justify-between group">
              <div class="min-w-0">
                <p class="text-sm text-gray-900 truncate"><%= invitation.email %></p>
                <% if membership = invitation.ballot_membership %>
                  <p class="text-xs text-gray-500">@<%= membership.profile.handle %></p>
                <% end %>
              </div>
              <%= link_to 'Remove',
                  my_ballot_ballot_invitation_path(@ballot, invitation),
                  data: { turbo_method: :delete, turbo_confirm: 'Are you sure?' },
                  class: "opacity-0 group-hover:opacity-100 text-xs text-gray-500 hover:text-red-600 transition-all duration-200" %>
            </div>
          <% end %>

          <%# Invite Form %>
          <div class="px-6 py-5 bg-gray-50/50">
            <%= form_tag bulk_create_my_ballot_ballot_invitations_path(@ballot), data: { turbo: false } do %>
              <div class="space-y-4">
                <div>
                  <label class="block text-sm font-medium text-gray-700">Invite Members</label>
                  <div class="mt-1.5">
                    <%= text_area_tag :emails, nil,
                        placeholder: 'Enter email addresses (comma separated or new lines)',
                        rows: 3,
                        class: "w-full px-3 py-2 bg-white border border-gray-300 rounded-lg shadow-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 sm:text-sm transition duration-200" %>
                  </div>
                </div>
                <div class="text-right">
                  <%= submit_tag "Send Invites",
                      class: "px-4 py-2 text-sm font-medium rounded-lg text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-all duration-200" %>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    <% end %>

    <%# Votes Section %>
    <div class="mb-8 bg-white rounded-xl shadow-sm border border-gray-200/75 overflow-hidden">
      <div class="px-6 py-5 border-b border-gray-200/75">
        <h2 class="text-sm font-medium text-gray-900">Votes</h2>
      </div>

      <div class="divide-y divide-gray-200/75">
        <% @ballot.votes.each do |vote| %>
          <div class="px-6 py-3 flex items-center justify-between">
            <div class="min-w-0">
              <p class="text-sm text-gray-900 truncate"><%= vote.profile_user_email %></p>
              <p class="text-xs text-gray-500"><%= vote.updated_at.strftime("%B %d, %Y at %I:%M %p") %></p>
            </div>
          </div>
        <% end %>

        <% if @ballot.votes.empty? %>
          <div class="px-6 py-8 text-center text-sm text-gray-500">
            No votes yet
          </div>
        <% end %>
      </div>
    </div>

    <%# Delete Section %>
    <div class="text-center">
      <%= link_to "Delete Ballot",
          my_ballot_path(@ballot),
          data: { turbo_method: :delete, turbo_confirm: 'Are you sure you want to delete this ballot?' },
          class: "text-sm text-gray-500 hover:text-red-600 transition-colors duration-200" %>
    </div>
  </div>
</div>
