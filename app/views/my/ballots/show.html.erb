<div class="min-h-screen bg-gray-50">
  <div class="max-w-4xl mx-auto px-4 py-12">
    <%# Header Section %>
    <div class="mb-8">
      <div class="flex items-start justify-between">
        <div>
          <h1 class="text-2xl font-medium text-gray-900"><%= @ballot.name %></h1>
          <% if @ballot.description.present? %>
            <p class="mt-2 text-gray-600"><%= @ballot.description %></p>
          <% end %>
        </div>
        <%= link_to edit_my_ballot_path(@ballot), class: "text-sm text-gray-600 hover:text-gray-900" do %>
          Edit
        <% end %>
      </div>
    </div>

    <%# Actions Section %>
    <div class="mb-8 bg-white rounded-xl shadow-sm border border-gray-200/75 overflow-hidden">
      <div class="px-6 py-5 flex items-center justify-between">
        <div>
          <% if @ballot.ends_at > Time.now %>
            <h2 class="text-sm font-medium text-gray-900">Voting Link</h2>
            <p class="mt-1 text-sm text-gray-500">Share this link with voters</p>
          <% else %>
            <h2 class="text-sm font-medium text-gray-900">Results</h2>
            <p class="mt-1 text-sm text-gray-500">View the final voting results</p>
          <% end %>
        </div>
        <div class="flex items-center gap-3">
          <% if @ballot.ends_at > Time.now %>
            <a href="<%= ballot_path %>" class="button button-primary">
              Open Vote
            </a>
            <a href="<%= results_ballot_path %>" class="button button-secondary">
              Results
            </a>
          <% else %>
            <a href="<%= results_ballot_path %>" class="button button-secondary">
              View Results
            </a>
          <% end %>
          <%= render_beta do %>
            <% link_to generate_my_ballot_option_path(@ballot), data: { turbo_method: "post", controller: "loading-button" }, class: "button button-secondary button-icon" do %>
              <svg class="icon" fill="yellow" viewBox="0 0 24 24" stroke-width="1.5" stroke="#FFAC33">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09ZM18.259 8.715 18 9.75l-.259-1.035a3.375 3.375 0 0 0-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 0 0 2.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 0 0 2.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 0 0-2.456 2.456ZM16.894 20.567 16.5 21.75l-.394-1.183a2.25 2.25 0 0 0-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 0 0 1.423-1.423l.394-1.183.394 1.183a2.25 2.25 0 0 0 1.423 1.423l1.183.394-1.183.394a2.25 2.25 0 0 0-1.423 1.423Z" />
              </svg>

              <svg aria-hidden="true" role="status" class="spinner hidden inline w-4 h-4 me-3 text-gray-200 animate-spin dark:text-gray-600" viewBox="0 0 100 101" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M100 50.5908C100 78.2051 77.6142 100.591 50 100.591C22.3858 100.591 0 78.2051 0 50.5908C0 22.9766 22.3858 0.59082 50 0.59082C77.6142 0.59082 100 22.9766 100 50.5908ZM9.08144 50.5908C9.08144 73.1895 27.4013 91.5094 50 91.5094C72.5987 91.5094 90.9186 73.1895 90.9186 50.5908C90.9186 27.9921 72.5987 9.67226 50 9.67226C27.4013 9.67226 9.08144 27.9921 9.08144 50.5908Z" fill="currentColor"/>
                <path d="M93.9676 39.0409C96.393 38.4038 97.8624 35.9116 97.0079 33.5539C95.2932 28.8227 92.871 24.3692 89.8167 20.348C85.8452 15.1192 80.8826 10.7238 75.2124 7.41289C69.5422 4.10194 63.2754 1.94025 56.7698 1.05124C51.7666 0.367541 46.6976 0.446843 41.7345 1.27873C39.2613 1.69328 37.813 4.19778 38.4501 6.62326C39.0873 9.04874 41.5694 10.4717 44.0505 10.1071C47.8511 9.54855 51.7191 9.52689 55.5402 10.0491C60.8642 10.7766 65.9928 12.5457 70.6331 15.2552C75.2735 17.9648 79.3347 21.5619 82.5849 25.841C84.9175 28.9121 86.7997 32.2913 88.1811 35.8758C89.083 38.2158 91.5421 39.6781 93.9676 39.0409Z" fill="#1C64F2"/>
              </svg>

              Suggest options
            <% end %>
          <% end %>
        </div>
      </div>
    </div>

    <%# Options Section %>
    <div class="mb-8 bg-white rounded-xl shadow-sm border border-gray-200/75 overflow-hidden">
      <div class="px-6 py-5 border-b border-gray-200/75">
        <h2 class="text-sm font-medium text-gray-900">Options</h2>
      </div>

      <div class="divide-y divide-gray-200/75">
        <% if @ballot.options.any? %>
          <% @ballot.options.each do |option| %>
            <div class="px-6 py-4 flex items-start justify-between group">
              <div>
                <h3 class="text-sm font-medium text-gray-900"><%= option.title %></h3>
                <p class="mt-1 text-sm text-gray-500"><%= option.description.presence || "-" %></p>
              </div>
              <%= link_to 'Remove',
                  my_ballot_option_path(@ballot, option),
                  data: { turbo_method: :delete, turbo_confirm: 'Are you sure?' },
                  class: "opacity-0 group-hover:opacity-100 text-xs text-gray-500 hover:text-red-600 transition-all duration-200" %>
            </div>
          <% end %>
        <% end %>

        <%# Add Option Form %>
        <div class="px-6 py-5 bg-gray-50/50">
          <%= form_with model: @option,
              url: my_ballot_options_path(@ballot),
              local: true,
              data: { turbo: false } do |f| %>
            <%= render "my/options/form", option: @option, f: f %>
          <% end %>
        </div>
      </div>
    </div>

    <%# Members Section (if private) %>
    <% if @ballot.private? %>
      <div class="mb-8 bg-white rounded-xl shadow-sm border border-gray-200/75 overflow-hidden">
        <div class="px-6 py-5 border-b border-gray-200/75">
          <h2 class="text-sm font-medium text-gray-900">Members</h2>
        </div>

        <%# Member List %>
        <div class="divide-y divide-gray-200/75">
          <% @ballot.invitations.each do |invitation| %>
            <div class="px-6 py-3 flex items-center justify-between group">
              <div class="min-w-0">
                <p class="text-sm text-gray-900 truncate"><%= invitation.email %></p>
                <% if membership = invitation.ballot_membership %>
                  <p class="text-xs text-gray-500">@<%= membership.profile.handle %></p>
                <% end %>
              </div>
              <%= link_to 'Remove',
                  my_ballot_ballot_invitation_path(@ballot, invitation),
                  data: { turbo_method: :delete, turbo_confirm: 'Are you sure?' },
                  class: "opacity-0 group-hover:opacity-100 text-xs text-gray-500 hover:text-red-600 transition-all duration-200" %>
            </div>
          <% end %>

          <%# Invite Form %>
          <div class="px-6 py-5 bg-gray-50/50">
            <%= form_tag bulk_create_my_ballot_ballot_invitations_path(@ballot), data: { turbo: false } do %>
              <div class="space-y-4">
                <div>
                  <label class="block text-sm font-medium text-gray-700">Invite Members</label>
                  <div class="mt-1.5">
                    <%= text_area_tag :emails, nil,
                        placeholder: 'Enter email addresses (comma separated or new lines)',
                        rows: 3,
                        class: "w-full px-3 py-2 bg-white border border-gray-300 rounded-lg shadow-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 sm:text-sm transition duration-200" %>
                  </div>
                </div>
                <div class="text-right">
                  <%= submit_tag "Send Invites",
                      class: "px-4 py-2 text-sm font-medium rounded-lg text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-all duration-200" %>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    <% end %>

    <%# Votes Section %>
    <div class="mb-8 bg-white rounded-xl shadow-sm border border-gray-200/75 overflow-hidden">
      <div class="px-6 py-5 border-b border-gray-200/75">
        <h2 class="text-sm font-medium text-gray-900">Votes</h2>
      </div>

      <div class="divide-y divide-gray-200/75">
        <% @ballot.votes.each do |vote| %>
          <div class="px-6 py-3 flex items-center justify-between">
            <div class="min-w-0">
              <p class="text-sm text-gray-900 truncate"><%= vote.profile_user_email || "Anonymous" %></p>
              <p class="text-xs text-gray-500"><%= vote.updated_at.strftime("%B %d, %Y at %I:%M %p") %></p>
            </div>
          </div>
        <% end %>

        <% if @ballot.votes.empty? %>
          <div class="px-6 py-8 text-center text-sm text-gray-500">
            No votes yet
          </div>
        <% end %>
      </div>
    </div>

    <%# Delete Section %>
    <div class="text-center">
      <%= link_to "Delete Ballot",
          my_ballot_path(@ballot),
          data: { turbo_method: :delete, turbo_confirm: 'Are you sure you want to delete this ballot?' },
          class: "button button-danger w-full" %>
    </div>
  </div>
</div>
