<% if @ballot.errors.any? %>
  <div class="mb-6 p-3 bg-red-50 rounded-lg border border-red-100">
    <div class="text-sm text-red-800">
      <% @ballot.errors.full_messages.each do |message| %>
        <div><%= message %></div>
      <% end %>
    </div>
  </div>
<% end %>

<div class="space-y-6">
  <div>
    <%= f.label :name, "Title", class: "block text-sm font-medium text-gray-700" %>
    <div class="mt-1.5">
      <%= f.text_field :name, 
          placeholder: "What are you voting on?",
          class: "w-full px-3 py-2 bg-white border border-gray-300 rounded-lg shadow-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 sm:text-sm transition duration-200",
          required: true %>
    </div>
  </div>

  <div>
    <%= f.label :description, "Description", class: "block text-sm font-medium text-gray-700" %>
    <div class="mt-1.5">
      <%= f.text_area :description, 
          rows: 3,
          placeholder: "Add some context...",
          class: "w-full px-3 py-2 bg-white border border-gray-300 rounded-lg shadow-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 sm:text-sm transition duration-200" %>
    </div>
  </div>

  <div>
    <%= f.label :ends_at, "End Date", class: "block text-sm font-medium text-gray-700" %>
    <div class="mt-1.5">
      <%= f.datetime_local_field :ends_at, 
          value: @ballot.ends_at&.strftime('%Y-%m-%dT%H:%M'),
          required: true,
          min: Time.current.strftime('%Y-%m-%dT%H:%M'),
          class: "w-full px-3 py-2 bg-white border border-gray-300 rounded-lg shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 sm:text-sm transition duration-200" %>
    </div>
  </div>

  <div>
    <div class="flex items-center justify-between mb-1.5">
      <span class="text-sm font-medium text-gray-700">Access</span>
    </div>
    <div class="bg-white rounded-lg border border-gray-300 divide-y divide-gray-200">
      <label class="flex items-center p-3 cursor-pointer hover:bg-gray-50 transition duration-200">
        <%= f.radio_button :private, "1", checked: "checked", class: "h-4 w-4 text-blue-600 focus:ring-blue-500 border-gray-300" %>
        <span class="ml-3 text-sm text-gray-900">Invite only</span>
      </label>
      <label class="flex items-center p-3 cursor-pointer hover:bg-gray-50 transition duration-200">
        <%= f.radio_button :private, "0", class: "h-4 w-4 text-blue-600 focus:ring-blue-500 border-gray-300" %>
        <span class="ml-3 text-sm text-gray-900">Anyone with link</span>
      </label>
    </div>
  </div>
</div>
