<div class="min-h-screen bg-gray-50">
  <div class="max-w-2xl mx-auto px-4 py-12">
    <% if @ballots.empty? %>
      <div class="text-center">
        <h1 class="text-2xl font-medium text-gray-900 mb-8">Create your first vote</h1>
        <%= link_to new_my_ballot_path, class: "inline-flex items-center px-4 py-2 text-sm font-medium rounded-lg text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-all duration-200" do %>
          <svg class="w-5 h-5 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
          </svg>
          New Vote
        <% end %>
      </div>
    <% else %>
      <div class="mb-10 flex items-center justify-between">
        <h1 class="text-2xl font-medium text-gray-900">Votes</h1>
        <%= link_to new_my_ballot_path, class: "inline-flex items-center px-4 py-2 text-sm font-medium rounded-lg text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-all duration-200" do %>
          <svg class="w-5 h-5 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
          </svg>
          New Vote
        <% end %>
      </div>

      <% active_ballots = @ballots.select { |b| b.ends_at > Time.current }
                                .sort_by { |b| [@voted_status[b.id] ? 1 : 0, b.ends_at] }
                                .first(10) %>
      <% completed_ballots = @ballots.select { |b| b.ends_at <= Time.current }
                                  .sort_by(&:ends_at)
                                  .reverse
                                  .first(10) %>

      <div class="space-y-10">
        <% if active_ballots.any? %>
          <section>
            <h2 class="text-xs font-medium uppercase tracking-wider text-gray-500 mb-3">Active</h2>
            <div class="bg-white rounded-xl divide-y border border-gray-200/75 shadow-sm">
              <% active_ballots.each do |ballot| %>
                <%= render "ballot_list_item", ballot: ballot, voted: @voted_status[ballot.id] %>
              <% end %>

              <% if @ballots.select { |b| b.ends_at > Time.current }.count > 10 %>
                <div class="px-4 py-3 bg-gray-50 text-center border-t border-gray-200/75">
                  <%= link_to my_ballots_path(status: 'active'), class: "text-xs font-medium text-blue-600 hover:text-blue-700 transition-colors duration-200" do %>
                    Show All
                  <% end %>
                </div>
              <% end %>
            </div>
          </section>
        <% end %>

        <% if completed_ballots.any? %>
          <section>
            <h2 class="text-xs font-medium uppercase tracking-wider text-gray-500 mb-3">Completed</h2>
            <div class="bg-white rounded-xl divide-y border border-gray-200/75 shadow-sm">
              <% completed_ballots.each do |ballot| %>
                <%= render "ballot_list_item", ballot: ballot, voted: @voted_status[ballot.id] %>
              <% end %>

              <% if @ballots.select { |b| b.ends_at <= Time.current }.count > 10 %>
                <div class="px-4 py-3 bg-gray-50 text-center border-t border-gray-200/75">
                  <%= link_to my_ballots_path(status: 'completed'), class: "text-xs font-medium text-blue-600 hover:text-blue-700 transition-colors duration-200" do %>
                    Show All
                  <% end %>
                </div>
              <% end %>
            </div>
          </section>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
