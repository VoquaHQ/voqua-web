<% if question.errors.any? %>
  <div class="mb-4 p-3 bg-red-50 rounded-lg border border-red-100">
    <div class="text-sm text-red-800">
      <% question.errors.full_messages.each do |message| %>
        <div><%= message %></div>
      <% end %>
    </div>
  </div>
<% end %>

<div class="space-y-4">
  <div>
    <%= f.label :title, "Option", class: "block text-sm font-medium text-gray-700" %>
    <div class="mt-1.5">
      <%= f.text_field :title,
          placeholder: "What can people vote on?",
          class: "w-full px-3 py-2 bg-white border border-gray-300 rounded-lg shadow-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 sm:text-sm transition duration-200" %>
    </div>
  </div>

  <div>
    <%= f.label :description, "Details", class: "block text-sm font-medium text-gray-700" %>
    <div class="mt-1.5">
      <%= f.text_area :description,
          rows: 2,
          placeholder: "Add some context...",
          class: "w-full px-3 py-2 bg-white border border-gray-300 rounded-lg shadow-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 sm:text-sm transition duration-200" %>
    </div>
  </div>

  <div class="pt-2 text-right">
    <%= f.submit "Add Option",
        class: "px-4 py-2 text-sm font-medium rounded-lg text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-all duration-200" %>
  </div>
</div>
