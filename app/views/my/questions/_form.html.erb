<% if @question.errors.any? %>
  <div class="mb-6 p-3 bg-red-50 rounded-lg border border-red-100">
    <div class="text-sm text-red-800">
      <% @question.errors.full_messages.each do |message| %>
        <div><%= message %></div>
      <% end %>
    </div>
  </div>
<% end %>

<div class="space-y-6">
  <div>
    <%= f.label :body, "Question", class: "block text-sm font-medium text-gray-700" %>
    <div class="mt-1.5">
      <%= f.text_area :body,
          rows: 4,
          placeholder: "What question do you want to ask?",
          class: "w-full px-3 py-2 bg-white border border-gray-300 rounded-lg shadow-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 sm:text-sm transition duration-200",
          required: true %>
    </div>
  </div>

  <div>
    <%= f.label :prompt, "LLM Prompt", class: "block text-sm font-medium text-gray-700" %>
    <p class="mt-1 text-xs text-gray-500">Instructions for the AI to generate follow-up questions. This is not visible to respondents.</p>
    <div class="mt-1.5">
      <%= f.text_area :prompt,
          rows: 4,
          placeholder: "e.g. You are an interviewer. Based on the answer, ask a follow-up question that digs deeper into the topic.",
          class: "w-full px-3 py-2 bg-white border border-gray-300 rounded-lg shadow-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 sm:text-sm transition duration-200",
          required: true %>
    </div>
  </div>
</div>
