<div class="min-h-screen bg-gray-50">
  <div class="max-w-4xl mx-auto px-4 py-12">
    <% if @questions.empty? %>
      <div class="text-center">
        <h1 class="font-medium text-gray-900 mb-8">Create your first question</h1>
        <%= link_to new_my_question_path, class: "inline-flex items-center px-4 py-2 font-medium rounded-lg text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-all duration-200" do %>
          <svg class="w-5 h-5 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
          </svg>
          New Question
        <% end %>
      </div>
    <% else %>
      <div class="mb-10 flex items-center justify-between">
        <h1 class="text-2xl font-medium text-gray-900">Questions</h1>
        <%= link_to new_my_question_path, class: "inline-flex items-center px-4 py-2 font-medium rounded-lg text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-all duration-200" do %>
          <svg class="w-5 h-5 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
          </svg>
          New Question
        <% end %>
      </div>

      <div class="bg-white rounded-xl divide-y border border-gray-200/75 shadow-sm">
        <% @questions.each do |question| %>
          <div class="px-6 py-4 flex items-center justify-between group">
            <div class="min-w-0">
              <%= link_to my_question_path(question), class: "text-sm font-medium text-gray-900 hover:text-blue-600 transition-colors duration-200" do %>
                <%= truncate(question.body, length: 80) %>
              <% end %>
              <p class="text-xs text-gray-500 mt-1">
                <%= question.interviews.count %> interviews
                &middot;
                <%= question.created_at.strftime("%B %d, %Y") %>
              </p>
            </div>
            <div class="flex items-center gap-3">
              <%= link_to "Edit", edit_my_question_path(question), class: "text-xs text-gray-500 hover:text-gray-900 transition-colors duration-200" %>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
