<div class="min-h-screen bg-gray-50">
  <div class="max-w-2xl mx-auto px-4 py-12">
    <h2 class="text-2xl font-medium text-gray-900 mb-6">Edit Question</h2>

    <div class="bg-white rounded-xl shadow-sm border border-gray-200/75">
      <%= form_with model: @question, url: my_question_path(@question), local: true, data: { turbo: false } do |f| %>
        <div class="p-6">
          <%= render 'form', question: @question, f: f %>
        </div>

        <div class="px-6 py-4 bg-gray-50 border-t border-gray-200/75 flex items-center justify-end gap-3">
          <%= link_to "Cancel", my_question_path(@question), class: "px-4 py-2 text-sm font-medium text-gray-700 hover:text-gray-800 transition-colors duration-200" %>
          <%= f.submit "Update Question", class: "px-4 py-2 text-sm font-medium rounded-lg text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-all duration-200" %>
        </div>
      <% end %>
    </div>

    <div class="mt-8 bg-white rounded-xl shadow-sm border border-gray-200/75">
      <div class="px-6 py-5 border-b border-gray-200/75">
        <h3 class="text-sm font-medium text-gray-900">Try it</h3>
        <p class="mt-1 text-xs text-gray-500">Test your prompt with a sample answer. Uses the current body and prompt from the form above (no need to save first).</p>
      </div>

      <div class="p-6">
        <%= form_with url: try_answer_my_question_path(@question),
                      method: :post,
                      data: { controller: "try-answer",
                              try_answer_body_field_value: "question_body",
                              try_answer_prompt_field_value: "question_prompt",
                              action: "turbo:submit-start->try-answer#submit turbo:submit-end->try-answer#complete" } do |f| %>
          <div>
            <%= f.label :answer, "Sample answer", class: "block text-sm font-medium text-gray-700" %>
            <div class="mt-1.5">
              <%= f.text_area :answer,
                  rows: 3,
                  placeholder: "Type a sample answer to test the follow-up...",
                  class: "w-full px-3 py-2 bg-white border border-gray-300 rounded-lg shadow-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 sm:text-sm transition duration-200" %>
            </div>
          </div>
          <div class="mt-4 flex items-center gap-3">
            <button type="submit" data-try-answer-target="button" class="px-4 py-2 text-sm font-medium rounded-lg text-white bg-gray-800 hover:bg-gray-900 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-gray-500 transition-all duration-200">
              Try
            </button>
            <span data-try-answer-target="spinner" class="hidden text-sm text-gray-500">Loading...</span>
          </div>
        <% end %>

        <div id="try-result" class="mt-4"></div>
      </div>
    </div>
  </div>
</div>
