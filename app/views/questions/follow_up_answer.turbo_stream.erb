<%= turbo_stream.replace "interview-area" do %>
  <div id="interview-area">
    <div class="bg-white rounded-xl shadow-sm border border-gray-200/75 p-6 mb-6">
      <p class="text-xs font-medium text-gray-500 mb-1">Your answer</p>
      <p class="text-sm text-gray-900"><%= @interview.first_answer %></p>
    </div>

    <div class="bg-white rounded-xl shadow-sm border border-gray-200/75 p-6 mb-6">
      <p class="text-xs font-medium text-gray-500 mb-1">Follow-up question</p>
      <p class="text-sm text-gray-900"><%= @interview.follow_up_question %></p>
    </div>

    <div class="bg-white rounded-xl shadow-sm border border-gray-200/75 p-6 mb-6">
      <p class="text-xs font-medium text-gray-500 mb-1">Your follow-up answer</p>
      <p class="text-sm text-gray-900"><%= @interview.follow_up_answer %></p>
    </div>

    <div class="bg-green-50 rounded-xl border border-green-200 p-6 mb-6 text-center">
      <p class="text-sm font-medium text-green-800">Thank you for your answers!</p>
      <p class="text-xs text-green-600 mt-1">You can optionally leave your phone number below.</p>
    </div>

    <div id="phone-area">
      <div class="bg-white rounded-xl shadow-sm border border-gray-200/75 p-6">
        <p class="text-sm font-medium text-gray-900 mb-4">Leave your phone number (optional)</p>
        <%= form_tag request_otp_question_path(@interview.question), data: { turbo: true } do %>
          <label class="block text-sm font-medium text-gray-700 mb-1.5">Phone number</label>
          <%= text_field_tag :phone_number, nil,
              placeholder: "+1234567890",
              class: "w-full px-3 py-2 bg-white border border-gray-300 rounded-lg shadow-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 sm:text-sm transition duration-200" %>
          <div class="mt-4 text-right">
            <%= submit_tag "Send verification code", class: "px-4 py-2 text-sm font-medium rounded-lg text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-all duration-200" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
<% end %>
