<div class="bg-gray-50 min-h-screen">
  <div class="max-w-2xl mx-auto px-4 py-12">
    <div class="bg-white rounded-xl shadow-sm border border-gray-200/75 p-8 mb-8">
      <h1 class="text-2xl font-medium text-gray-900 mb-4"><%= @question.body %></h1>
    </div>

    <div id="interview-area">
      <%= form_tag answer_question_path(@question), data: { turbo: true } do %>
        <div class="bg-white rounded-xl shadow-sm border border-gray-200/75 p-6">
          <label class="block text-sm font-medium text-gray-700 mb-1.5">Your answer</label>
          <%= text_area_tag :answer, nil,
              rows: 4,
              placeholder: "Type your answer...",
              class: "w-full px-3 py-2 bg-white border border-gray-300 rounded-lg shadow-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 sm:text-sm transition duration-200",
              required: true %>
          <div class="mt-4 text-right">
            <%= submit_tag "Submit", class: "px-4 py-2 text-sm font-medium rounded-lg text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-all duration-200" %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>
