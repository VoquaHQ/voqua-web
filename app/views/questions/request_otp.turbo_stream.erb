<%= turbo_stream.replace "phone-area" do %>
  <div id="phone-area">
    <% if @phone_error.present? %>
      <div class="bg-white rounded-xl shadow-sm border border-gray-200/75 p-6">
        <div class="mb-4 p-3 bg-red-50 rounded-lg border border-red-100">
          <p class="text-sm text-red-800"><%= @phone_error %></p>
        </div>
        <p class="text-sm font-medium text-gray-900 mb-4">Leave your phone number (optional)</p>
        <%= form_tag request_otp_question_path(@question), data: { turbo: true } do %>
          <label class="block text-sm font-medium text-gray-700 mb-1.5">Phone number</label>
          <%= text_field_tag :phone_number, nil,
              placeholder: "+1234567890",
              class: "w-full px-3 py-2 bg-white border border-gray-300 rounded-lg shadow-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 sm:text-sm transition duration-200" %>
          <div class="mt-4 text-right">
            <%= submit_tag "Send verification code", class: "px-4 py-2 text-sm font-medium rounded-lg text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-all duration-200" %>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="bg-white rounded-xl shadow-sm border border-gray-200/75 p-6">
        <p class="text-sm font-medium text-gray-900 mb-4">Enter the verification code</p>
        <%= form_tag verify_otp_question_path(@question), data: { turbo: true } do %>
          <label class="block text-sm font-medium text-gray-700 mb-1.5">Verification code</label>
          <%= text_field_tag :otp_code, nil,
              placeholder: "123456",
              maxlength: 6,
              class: "w-full px-3 py-2 bg-white border border-gray-300 rounded-lg shadow-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 sm:text-sm transition duration-200" %>
          <div class="mt-4 text-right">
            <%= submit_tag "Verify", class: "px-4 py-2 text-sm font-medium rounded-lg text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-all duration-200" %>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>
<% end %>
