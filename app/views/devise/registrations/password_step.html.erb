<section class="text-center">
  <div class="pt-8 text-left mx-auto w-full md:mt-0 sm:max-w-md xl:p-0">
    <h1 class="text-xl font-bold leading-tight tracking-tight text-gray-900 md:text-2xl text-center my-2">
      Create your password
    </h1>

    <%= render "devise/shared/error_messages", resource: resource %>

    <div class="px-6 md:space-y-4 sm:px-8">
      <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "space-y-4 md:space-y-6" }, data: { turbo: false, controller: "password-validation" }) do |f| %>
        <div class="mb-4 space-y-3">
          <div class="flex items-center justify-between">
            <div class="flex items-center">
              <div class="w-8 h-8 bg-blue-100 rounded-full flex items-center justify-center">
                <span class="text-blue-600 text-sm">✓</span>
              </div>
              <div class="ml-3">
                <p class="text-sm font-medium text-gray-900"><%= @email %></p>
                <%= link_to "Change", new_user_registration_path, class: "text-xs text-blue-600 hover:underline" %>
              </div>
            </div>
          </div>

          <div class="flex items-center justify-between">
            <div class="flex items-center">
              <div class="w-8 h-8 bg-blue-100 rounded-full flex items-center justify-center">
                <span class="text-blue-600 text-sm">✓</span>
              </div>
              <div class="ml-3">
                <p class="text-sm font-medium text-gray-900"><%= @first_name %> <%= @last_name %></p>
                <%= link_to "Change", new_user_registration_path(email: @email), class: "text-xs text-blue-600 hover:underline" %>
              </div>
            </div>
          </div>
        </div>

        <%= f.hidden_field :email, value: @email %>
        <%= f.hidden_field :first_name, value: @first_name %>
        <%= f.hidden_field :last_name, value: @last_name %>
        <%= f.fields_for :main_profile do |fp| %>
          <%= fp.hidden_field :handle %>
        <% end %>

        <div>
          <label for="user_password" class="block mb-2 text-sm font-medium text-gray-900">
            Password
            <% if @minimum_password_length %>
              <span class="text-gray-500 font-normal">(<%= @minimum_password_length %> characters minimum)</span>
            <% end %>
          </label>
          <%= f.password_field :password, autofocus: true, autocomplete: "new-password",
              placeholder: "••••••••",
              class: "placeholder:text-gray-300 bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-primary-600 focus:border-primary-600 block w-full p-2.5",
              data: { password_validation_target: "password", action: "input->password-validation#validate" } %>
        </div>

        <div>
          <label for="user_password_confirmation" class="block mb-2 text-sm font-medium text-gray-900">Confirm password</label>
          <%= f.password_field :password_confirmation, autocomplete: "new-password",
              placeholder: "••••••••",
              class: "placeholder:text-gray-300 bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-primary-600 focus:border-primary-600 block w-full p-2.5",
              data: { password_validation_target: "confirmation", action: "input->password-validation#validate" } %>
          <p data-password-validation-target="error" class="mt-1 text-sm text-red-600 hidden">
            Passwords do not match
          </p>
        </div>

        <button type="submit" class="w-full text-white bg-blue-600 hover:bg-blue-700 focus:ring-4 focus:outline-none focus:ring-blue-300 font-medium rounded-lg text-sm px-5 py-2.5 text-center transition-colors duration-200"
            data-password-validation-target="submit">
          Create account
        </button>

        <div class="text-sm text-center">
          Already have an account?
          <%= link_to "Sign in", new_session_path(resource_name), class: "text-blue-600 hover:underline" %>
        </div>
      <% end %>
    </div>
  </div>
</section>
