<section class="text-center">
  <div class="pt-8 text-left mx-auto w-full md:mt-0 sm:max-w-md xl:p-0">
    <h1 class="text-xl font-bold leading-tight tracking-tight text-gray-900 md:text-2xl text-center my-2">
      Set new password
    </h1>

    <p class="text-sm text-gray-600 text-center mb-6">
      Choose a strong password to protect your account
    </p>

    <div class="px-6 md:space-y-4 sm:px-8">
      <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put, class: "space-y-4 md:space-y-6" }) do |f| %>
        <%= render "devise/shared/error_messages", resource: resource %>
        <%= f.hidden_field :reset_password_token %>

        <div>
          <label for="user_password" class="block mb-2 text-sm font-medium text-gray-900">
            New password
            <% if @minimum_password_length %>
              <span class="text-gray-500 font-normal">(<%= @minimum_password_length %> characters minimum)</span>
            <% end %>
          </label>
          <%= f.password_field :password, autofocus: true, autocomplete: "new-password", placeholder: "••••••••",
              class: "placeholder:text-gray-300 bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-primary-600 focus:border-primary-600 block w-full p-2.5" %>
        </div>

        <div>
          <label for="user_password_confirmation" class="block mb-2 text-sm font-medium text-gray-900">Confirm new password</label>
          <%= f.password_field :password_confirmation, autocomplete: "new-password", placeholder: "••••••••",
              class: "placeholder:text-gray-300 bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-primary-600 focus:border-primary-600 block w-full p-2.5" %>
        </div>

        <button type="submit" class="w-full text-white bg-blue-600 hover:bg-blue-700 focus:ring-4 focus:outline-none focus:ring-blue-300 font-medium rounded-lg text-sm px-5 py-2.5 text-center">
          Change password
        </button>

        <div class="text-sm text-center">
          <%= link_to "Back to sign in", new_session_path(resource_name), class: "text-blue-600 hover:underline" %>
        </div>
      <% end %>
    </div>
  </div>
</section>
