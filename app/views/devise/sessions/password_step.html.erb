<section class="text-center">
  <div class="pt-8 text-left mx-auto w-full md:mt-0 sm:max-w-md xl:p-0">
    <h1 class="text-xl font-bold leading-tight tracking-tight text-gray-900 md:text-2xl text-center my-2">
      Enter your password
    </h1>

    <div class="px-6 md:space-y-4 sm:px-8">
      <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "space-y-4 md:space-y-6" }, data: { turbo: false }) do |f| %>
        <div class="mb-4">
          <div class="flex items-center justify-between">
            <div class="flex items-center">
              <div class="w-8 h-8 bg-blue-100 rounded-full flex items-center justify-center">
                <span class="text-blue-600 text-sm">✓</span>
              </div>
              <div class="ml-3">
                <p class="text-sm font-medium text-gray-900"><%= @email %></p>
                <%= link_to "Change", new_user_session_path, class: "text-xs text-blue-600 hover:underline" %>
              </div>
            </div>
          </div>
        </div>

        <%= f.hidden_field :email, value: @email %>

        <div>
          <label for="user_password" class="block mb-2 text-sm font-medium text-gray-900">Password</label>
          <%= f.password_field :password, autofocus: true, autocomplete: "current-password", placeholder: "••••••••",
              class: "placeholder:text-gray-300 bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-primary-600 focus:border-primary-600 block w-full p-2.5" %>
        </div>

        <% if devise_mapping.rememberable? %>
          <div class="flex items-center">
            <%= f.check_box :remember_me, checked: true, class: "w-4 h-4 border border-gray-300 rounded bg-gray-50 focus:ring-3 focus:ring-blue-300" %>
            <%= f.label :remember_me, class: "ml-2 text-sm text-gray-600" %>
          </div>
        <% end %>

        <button type="submit" class="w-full text-white bg-blue-600 hover:bg-blue-700 focus:ring-4 focus:outline-none focus:ring-blue-300 font-medium rounded-lg text-sm px-5 py-2.5 text-center transition-colors duration-200">
          Sign in
        </button>

        <div class="space-y-2 text-sm text-gray-600">
          <%- if devise_mapping.recoverable? %>
            <div>
              <%= link_to "Forgot your password?", new_password_path(resource_name), class: "text-blue-600 hover:underline" %>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
</section>
