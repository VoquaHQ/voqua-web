<h1 class="title">Welcome Back to Voqua</h1>
<% if @resource.pending_vote_token %>
  <p class="subtitle">Get started with quadratic voting</p>
<% else %>
  <p class="subtitle">Access your quadratic voting dashboard</p>
<% end %>

<% if @resource.pending_vote_token %>
  <div class="benefits">
    <p class="benefits-title">✓ Create Your Own Votes</p>
    <p>Design and run quadratic votes to gather insights from your team or community.</p>

    <p class="benefits-title">✓ Harness Collective Intelligence</p>
    <p>Make faster, better decisions by leveraging the wisdom of your group.</p>
  </div>

  <div style="text-align: center;">
    <%= link_to "Create My Account", users_custom_magic_link_url(@scope_name => {email: @resource.email, token: @token, remember_me: @remember_me, pending_vote_token: @resource.pending_vote_token}), class: 'button' %>
  </div>
<% else %>
  <p style="text-align: center;">Click the button below to access your Voqua account:</p>

  <div style="text-align: center;">
    <%= link_to "Log In to Voqua", users_custom_magic_link_url(@scope_name => {email: @resource.email, token: @token, remember_me: @remember_me, pending_vote_token: @resource.pending_vote_token}), class: 'button' %>
  </div>
<% end %>
