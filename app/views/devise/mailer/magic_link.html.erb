<% if @resource.pending_vote_token %>
  <h1 class="title">Thank You for Voting!</h1>
  <p class="subtitle">One quick step to enhance your vote's impact</p>
<% else %>
  <h1 class="title">Welcome Back to Voqua</h1>
  <p class="subtitle">Access your quadratic voting dashboard</p>
<% end %>

<% if @resource.pending_vote_token %>
  <div class="benefits">
    <p class="benefits-title">✓ Validate your contribution</p>
    <p>Email verification helps ensure the quality and reliability of collective decision-making.</p>

    <p class="benefits-title">✓ Unlock Voqua's full potential</p>
    <p>Create and run your own quadratic votes to harness collective intelligence for faster, better decisions.</p>
  </div>

  <div style="text-align: center;">
    <%= link_to "Confirm My Vote", users_custom_magic_link_url(@scope_name => {email: @resource.email, token: @token, remember_me: @remember_me, pending_vote_token: @resource.pending_vote_token}), class: 'button' %>
  </div>
<% else %>
  <p style="text-align: center;">Click the button below to access your Voqua account:</p>

  <div style="text-align: center;">
    <%= link_to "Log In to Voqua", users_custom_magic_link_url(@scope_name => {email: @resource.email, token: @token, remember_me: @remember_me, pending_vote_token: @resource.pending_vote_token}), class: 'button' %>
  </div>
<% end %>
