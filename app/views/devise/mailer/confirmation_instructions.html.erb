<% if @resource.pending_vote_token %>
  <h1 class="title">Thank You for Voting!</h1>
  <p class="subtitle">One quick step to enhance your vote's impact</p>
<% else %>
  <h1 class="title">Welcome to Voqua</h1>
  <p class="subtitle">Your gateway to better group decision-making</p>
<% end %>

<% if @resource.pending_vote_token %>
  <div class="benefits">
    <p class="benefits-title">✓ Validate your contribution</p>
    <p>Email verification helps ensure the quality and reliability of collective decision-making.</p>

    <p class="benefits-title">✓ Unlock Voqua's full potential</p>
    <p>Create and run your own quadratic votes to harness collective intelligence for faster, better decisions.</p>
  </div>

  <div style="text-align: center;">
    <%= link_to 'Confirm My Vote', confirmation_url(@resource, confirmation_token: @token, pending_vote_token: @resource.pending_vote_token), class: 'button' %>
  </div>
<% else %>
  <p>Please confirm your email address to start using Voqua's quadratic voting platform.</p>

  <div style="text-align: center;">
    <%= link_to 'Confirm Email', confirmation_url(@resource, confirmation_token: @token, pending_vote_token: @resource.pending_vote_token), class: 'button' %>
  </div>
<% end %>

