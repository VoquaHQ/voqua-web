<h1 class="text-2xl font-bold mb-4">Your Ballots</h1>

<%= link_to 'Create New Ballot', new_ballot_path, class: 'bg-blue-500 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded' %>

<div class="mt-4">
  <% @ballots.each do |ballot| %>
    <div class="bg-white shadow-md rounded px-8 pt-6 pb-8 mb-4">
      <h2 class="text-xl font-semibold"><%= ballot.title %></h2>
      <p class="text-gray-600"><%= ballot.description %></p>
      <p class="text-sm text-gray-500">Deadline: <%= ballot.deadline.strftime("%B %d, %Y at %I:%M %p") %></p>
      <div class="mt-4">
        <%= link_to 'View', ballot_path(ballot), class: 'bg-blue-500 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded mr-2' %>
        <%= link_to 'Edit', edit_ballot_path(ballot), class: 'bg-yellow-500 hover:bg-yellow-700 text-white font-bold py-2 px-4 rounded mr-2' %>
        <%= link_to 'Delete', ballot_path(ballot), method: :delete, data: { confirm: 'Are you sure?' }, class: 'bg-red-500 hover:bg-red-700 text-white font-bold py-2 px-4 rounded' %>
      </div>
    </div>
  <% end %>
</div>
