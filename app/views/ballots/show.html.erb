<div class="min-h-screen bg-gray-50">
  <div class="max-w-5xl mx-auto px-4 py-8">
    <div class="bg-white rounded-lg shadow-sm p-8 mb-8">
      <h1 class="text-3xl font-semibold text-gray-900 mb-3"><%= @ballot.name %></h1>
      <p class="text-lg text-gray-600 leading-relaxed"><%= @ballot.description %></p>
    </div>

    <% if @ballot.questions.empty? %>
      <div class="bg-white rounded-lg shadow-sm p-8 text-center">
        <p class="text-gray-600">No options have been added to this feedback collection yet.</p>
      </div>
    <% else %>
      <div id="voting" data-controller="voting">
        <div class="flex gap-8">
          <div class="w-64 sticky top-8 h-fit">
            <div class="bg-white rounded-lg shadow-sm p-6">
              <h2 class="font-medium text-gray-900 mb-2">Available Credits</h2>
              <div class="flex items-baseline gap-2 mb-4">
                <span class="text-3xl font-bold text-blue-600" data-credits="99">99</span>
                <span class="text-sm text-gray-500">remaining</span>
              </div>
              <div data-all-credits="0">
                <%= render partial: "remaining_credits_svg" %>
              </div>
              <p class="mt-4 text-sm text-gray-500">Use your credits to express the strength of your preferences.</p>
            </div>
          </div>

          <div class="flex-1">
            <%= form_tag ballot_submit_votes_path(@ballot), data: { turbo: false } do %>
              <div class="space-y-8">
                <% @ballot.questions.each.with_index do |question, i| %>
                  <div class="bg-white rounded-lg shadow-sm" data-question-id="<%= question.id %>" data-state="">
                    <div class="p-6 border-b border-gray-100">
                      <div class="text-sm font-medium text-blue-600 mb-2">Option <%= i + 1 %> of <%= @ballot.questions.size %></div>
                      <h3 class="text-xl font-medium text-gray-900 mb-2"><%= question.title %></h3>
                      <p class="text-gray-600"><%= question.description %></p>
                    </div>

                    <div class="flex p-6">
                      <div class="w-1/4" data-credits-for>
                        <%= render partial: "credits_svg", locals: { flipped: false } %>
                      </div>
                      <div class="w-2/4">
                        <div class="flex items-center justify-center space-x-12 pt-4">
                          <div data-vote-type="for" class="text-right flex flex-col items-end">
                            <div class="mb-2">
                              <span class="vote-type-label-for text-sm font-medium text-gray-900">In favour</span>
                            </div>
                            <button data-vote-button="inc" class="vote-button vote-button-for bg-white hover:bg-gray-900 text-gray-900 font-medium hover:text-white py-2 px-4 border border-gray-900 hover:border-transparent rounded-md transition-colors">
                              <span class="vote">Vote</span>
                              <span class="more">More</span>
                              <span class="fewer">Fewer</span>
                            </button>
                            <div class="mt-2 min-h-[1.5rem]">
                              <%= render partial: "votes_count_fields", locals: { 
                                question_id: question.id, 
                                type: :for, 
                                votes_count: (@votes&.data&.dig(question.id.to_s) || {})["for"].to_i
                              } %>
                            </div>
                          </div>
                          <div data-vote-type="against" class="text-left flex flex-col items-start">
                            <div class="mb-2">
                              <span class="vote-type-label-against text-sm font-medium text-red-700">Opposed</span>
                            </div>
                            <button data-vote-button="inc" class="vote-button vote-button-against bg-white hover:bg-red-600 text-red-700 font-medium hover:text-white py-2 px-4 border border-red-600 hover:border-transparent rounded-md transition-colors">
                              <span class="vote">Vote</span>
                              <span class="more">More</span>
                              <span class="fewer">Fewer</span>
                            </button>
                            <div class="mt-2 min-h-[1.5rem]">
                              <%= render partial: "votes_count_fields", locals: { 
                                question_id: question.id, 
                                type: :against, 
                                votes_count: (@votes&.data&.dig(question.id.to_s) || {})["against"].to_i
                              } %>
                            </div>
                          </div>
                        </div>
                      </div>
                      <div class="w-1/4" data-credits-against>
                        <%= render partial: "credits_svg", locals: { flipped: true } %>
                      </div>
                    </div>
                  </div>
                <% end %>

                <div class="text-center">
                  <%= submit_tag "Submit Feedback", class: "bg-blue-600 hover:bg-blue-700 text-white font-medium py-3 px-6 rounded-md transition-colors" %>
                </div>
              </div>
            <% end %>
          </div>

          <div class="w-64 sticky top-8 h-fit">
            <div class="bg-white rounded-lg shadow-sm p-6">
              <h2 class="font-medium text-gray-900 mb-2">How It Works</h2>
              <ul class="text-sm text-gray-600 space-y-3">
                <li>• Use credits to express your preferences</li>
                <li>• More credits = stronger preference</li>
                <li>• Each additional vote costs more</li>
                <li>• Allocate wisely across options</li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>
