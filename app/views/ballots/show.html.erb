<div class="bg-gray-50">
  <div class="max-w-5xl mx-auto px-4 py-8">
    <div class="bg-white rounded-lg shadow-sm p-8 mb-8">
      <h1 class="text-3xl font-semibold text-gray-900 mb-3"><%= @ballot.name %></h1>
      <p class="text-lg text-gray-600 leading-relaxed"><%= @ballot.description %></p>
    </div>

    <!-- Quick Guide -->
    <div data-controller="onboarding" data-dismiss="quick-guide" id="quick-guide" class="bg-blue-50 border border-blue-100 rounded-lg p-6 mb-8 relative">
      <button data-action="dismiss" class="absolute top-4 right-4 text-blue-400 hover:text-blue-600">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
      <h2 class="text-xl font-medium text-blue-900 mb-4">Quick Guide</h2>
      <p class="text-blue-800 mb-2">You have <span class="font-bold">99 points</span> to vote with. For each option, you can vote multiple times in favor or against. Each extra vote costs more points!</p>
    </div>

    <% if @ballot.questions.empty? %>
      <div class="bg-white rounded-lg shadow-sm p-8 text-center">
        <p class="text-gray-600">No options have been added to this feedback collection yet.</p>
      </div>
    <% else %>
      <div id="voting" data-controller="voting">
        <div class="flex gap-2 md:gap-8">
          <div class="w-20 md:w-56 sticky top-8 h-fit">
            <div class="bg-white rounded-lg shadow-sm p-2 md:p-6">
              <h2 class="font-medium text-gray-900 mb-2">Your Voting Points</h2>
              <div class="items-baseline gap-2 mb-4">
                <span class="text-3xl font-bold text-blue-600" data-credits="99">99</span>
                <span class="text-sm text-gray-500 block md:inline">points left</span>
              </div>
              <div data-all-credits="0">
                <%= render partial: "remaining_credits_svg" %>
              </div>
            </div>
          </div>

          <div class="flex-1">
            <%= form_tag submit_votes_ballot_path(@ballot), data: { turbo: false } do %>
              <div class="space-y-8">
                <% @ballot.questions.each.with_index do |question, i| %>
                  <div class="bg-white rounded-lg shadow-sm" data-question-id="<%= question.id %>" data-state="">
                    <div class="p-2 md:p-6 border-b border-gray-100">
                      <div class="text-sm font-medium text-blue-600 mb-2">Option <%= i + 1 %> of <%= @ballot.questions.size %></div>
                      <h3 class="text-xl font-medium text-gray-900 mb-2"><%= question.title %></h3>
                      <p class="text-gray-600"><%= question.description %></p>
                    </div>

                    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 p-6 ">

                      <div class="order-2 md:order-1 col-span-1" data-credits-for>
                        <%= render partial: "credits_svg", locals: { class_name: "for", flipped: false } %>
                      </div>

                      <div class="order-1 md:order-2 col-span-2">
                        <div class="flex items-stretch justify-between pt-4">
                          <div data-vote-type="for" class="text-center">
                            <div class="mb-3">
                              <span class="vote-type-label-for text-sm font-medium text-gray-900">Support This</span>
                            </div>
                            <button data-vote-button="inc" class="vote-button vote-button-for bg-white hover:bg-gray-900 text-gray-900 font-medium hover:text-white py-2 px-6 border border-gray-900 hover:border-transparent rounded-md transition-colors min-w-[100px]">
                              <span class="vote">Vote</span>
                              <span class="more">More</span>
                              <span class="fewer">Fewer</span>
                            </button>
                            <div class="mt-3">
                              <%= votes_count_fields_for(@ballot, question.id, :for, @votes) %>
                            </div>
                          </div>
                          <div data-vote-type="against" class="text-center">
                            <div class="mb-3">
                              <span class="vote-type-label-against text-sm font-medium text-red-700">Oppose This</span>
                            </div>
                            <button data-vote-button="inc" class="vote-button vote-button-against bg-white hover:bg-red-600 text-red-700 font-medium hover:text-white py-2 px-6 border border-red-600 hover:border-transparent rounded-md transition-colors min-w-[100px]">
                              <span class="vote">Vote</span>
                              <span class="more">More</span>
                              <span class="fewer">Fewer</span>
                            </button>
                            <div class="mt-3">
                              <%= votes_count_fields_for(@ballot, question.id, :against, @votes) %>
                            </div>
                          </div>
                        </div>
                      </div>

                      <div class="order-3 col-span-1" data-credits-against>
                        <%= render partial: "credits_svg", locals: { class_name: "against", flipped: true } %>
                      </div>
                    </div>
                  </div>
                <% end %>

                <div class="text-center">
                  <%= submit_tag "Submit Votes", class: "button button-primary text-lg" %>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>
