<section class="min-h-screen bg-gray-50 flex flex-col items-center justify-center py-12 px-4 sm:px-6 lg:px-8">
  <div class="w-full max-w-md space-y-8 bg-white p-8 rounded-lg shadow-sm">
    <div>
      <h1 class="text-xl font-bold leading-tight tracking-tight text-gray-900 md:text-2xl text-center">
        Verify your phone number
      </h1>
      <p class="mt-2 text-sm text-gray-600 text-center">
        This ballot requires phone verification. Enter your mobile number to receive a one-time code.
      </p>
      <% if @ballot.allowed_country_code.present? %>
        <p class="mt-1 text-sm text-blue-600 text-center font-medium">
          Requires a phone number from: <%= @ballot.allowed_country_code %>
        </p>
      <% end %>
    </div>

    <% if flash[:alert].present? %>
      <div class="rounded-md bg-red-50 p-4">
        <p class="text-sm text-red-700"><%= flash[:alert] %></p>
      </div>
    <% end %>

    <%= form_tag request_otp_ballot_path(@ballot), method: :post, data: { turbo: false }, class: "mt-4 space-y-6" do %>
      <%= hidden_field_tag :vote_data, @vote_data %>
      <div>
        <label for="phone_number" class="block text-sm font-medium text-gray-700">Mobile number</label>
        <div class="mt-1">
          <input type="tel"
                 id="phone_number"
                 name="phone_number"
                 required
                 autofocus
                 placeholder="+49..."
                 class="appearance-none block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm placeholder-gray-400 focus:outline-none focus:ring-blue-500 focus:border-blue-500 sm:text-sm" />
        </div>
        <p class="mt-1 text-xs text-gray-500">Include country code, e.g. +49 for Germany</p>
      </div>

      <button type="submit" class="group relative w-full flex justify-center py-2.5 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500">
        Send code
      </button>
    <% end %>
  </div>
</section>
