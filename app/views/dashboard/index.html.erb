<div class="container mx-auto px-4">
  <h1 class="text-3xl font-bold mb-6">Dashboard</h1>

  <div class="mb-8">
    <h2 class="text-2xl font-semibold mb-4">Your Ballots</h2>
    <% if @user_ballots.any? %>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        <% @user_ballots.each do |ballot| %>
          <div class="bg-white shadow-md rounded-lg p-6">
            <h3 class="text-xl font-semibold mb-2"><%= ballot.title %></h3>
            <p class="text-gray-600 mb-4"><%= truncate(ballot.description, length: 100) %></p>
            <p class="text-sm text-gray-500 mb-4">Deadline: <%= ballot.deadline.strftime("%B %d, %Y at %I:%M %p") %></p>
            <%= link_to 'View Ballot', ballot_path(ballot), class: 'bg-blue-500 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded' %>
          </div>
        <% end %>
      </div>
    <% else %>
      <p>You haven't created any ballots yet.</p>
    <% end %>
    <%= link_to 'Create New Ballot', new_ballot_path, class: 'mt-4 inline-block bg-green-500 hover:bg-green-700 text-white font-bold py-2 px-4 rounded' %>
  </div>

  <div>
    <h2 class="text-2xl font-semibold mb-4">Accessible Ballots</h2>
    <% if @accessible_ballots.any? %>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        <% @accessible_ballots.each do |ballot| %>
          <div class="bg-white shadow-md rounded-lg p-6">
            <h3 class="text-xl font-semibold mb-2"><%= ballot.title %></h3>
            <p class="text-gray-600 mb-4"><%= truncate(ballot.description, length: 100) %></p>
            <p class="text-sm text-gray-500 mb-4">Deadline: <%= ballot.deadline.strftime("%B %d, %Y at %I:%M %p") %></p>
            <%= link_to 'View Ballot', ballot_path(ballot), class: 'bg-blue-500 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded' %>
          </div>
        <% end %>
      </div>
    <% else %>
      <p>There are no accessible ballots at the moment.</p>
    <% end %>
  </div>
</div>
